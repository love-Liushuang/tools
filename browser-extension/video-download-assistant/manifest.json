{
  "manifest_version": 3,
  "name": "ABIGBOOK 视频下载助手",
  "description": "本地捕获当前网页的视频直链、HLS 与 Bilibili DASH 信息，不依赖第三方解析服务。",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "视频下载助手",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-generic.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.bilibili.com/*",
        "*://player.bilibili.com/*"
      ],
      "js": [
        "content-bilibili-main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ]
}
